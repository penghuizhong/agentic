# ==========================================
# 1. 基础全局忽略 (根目录及所有子目录生效)
# ==========================================
.DS_Store
Thumbs.db
*.log
*.tmp
*.swp
.vscode/
.idea/
.ruff_cache/

# ==========================================
# 2. 前端项目忽略 (针对 ai_server_web_next 目录)
# ==========================================
ai_server_web_next/node_modules/
ai_server_web_next/.pnpm-store/
ai_server_web_next/.next/
ai_server_web_next/out/
ai_server_web_next/build/
ai_server_web_next/dist/
ai_server_web_next/coverage/
ai_server_web_next/.cache/
ai_server_web_next/*.tsbuildinfo

# 前端环境变量（保护您的敏感配置）
ai_server_web_next/.env
ai_server_web_next/.env.local
ai_server_web_next/.env.*.local
!ai_server_web_next/.env.example

# ==========================================
# 3. 后端项目忽略 (针对 ai_server 目录)
# ==========================================
ai_server/venv/
ai_server/env/
ai_server/.venv/
ai_server/__pycache__/
ai_server/**/*.py[cod]
ai_server/**/*.py.class
ai_server/.pytest_cache/
ai_server/.coverage
ai_server/htmlcov/

# 数据库文件 (防止把本地测试数据传上去)
ai_server/*.db
ai_server/*.sqlite
ai_server/*.sqlite3

# 上传的媒体文件
ai_server/uploads/
ai_server/media/

# 后端环境变量
ai_server/.env
ai_server/.env.*
!ai_server/.env.example