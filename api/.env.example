# OpenAI模型API密钥
OPENAI_API_KEY=    

 # Azure OpenAI模型API密钥
AZURE_OPENAI_API_KEY=
                                  
# Deepseek模型API密钥
DEEPSEEK_API_KEY=

# 阿里云达摩院DashScope模型API密钥
DASHSCOPE_API_KEY=   

# Anthropic模型API密钥
ANTHROPIC_API_KEY=                                      

# Google模型API密钥
GOOGLE_API_KEY=                                         

# Groq模型API密钥
GROQ_API_KEY=                                           

# OpenRouter模型API密钥
OPENROUTER_API_KEY=                                     

# 是否使用AWS Bedrock模型
USE_AWS_BEDROCK=false                                   


# 用于生成文本嵌入的模型名称，默认为text-embedding-v3
EMBEDDING_MODEL_NAME=text-embedding-v3

# Google Vertex AI的服务账户JSON密钥文件路径
GOOGLE_APPLICATION_CREDENTIALS=                         

# Amazon Bedrock知识库ID
AWS_KB_ID="<knowledge-base-id>"

# 使用假模型进行测试
USE_FAKE_MODEL=false

# 设置默认模型
DEFAULT_MODEL=qwen-turbo

# 如果MODEL设置为"openai-compatible"，请设置以下内容
# 这只是一个灵活的解决方案。如果需要多个模型选项，仍然需要将其添加到models.py中
COMPATIBLE_MODEL=
COMPATIBLE_API_KEY=
COMPATIBLE_BASE_URL=

# Web服务器配置
HOST=0.0.0.0
PORT=8000

# 认证密钥，如果设置了则需要HTTP bearer token头
AUTH_SECRET=

# Langsmith配置
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=default
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# 应用程序模式。如果值为"dev"，将启用uvicorn重载
MODE=


# 如果DATABASE_TYPE=postgres
# Docker Compose默认值（适用于docker-compose设置）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres    # Docker 部署改为服务名：postgres  # 服务器部署改为 localhost
POSTGRES_PORT=5432
POSTGRES_DB=fyzb

TABLE_NAME_PREFIX=agent_server_  # 应用程序在PostgreSQL中创建的所有表的前缀

# 您将能够在PostgreSQL连接管理器中通过此应用程序名称识别AST连接
POSTGRES_APPLICATION_NAME = "agent_service"
# 设置这些值以自定义连接池中的连接数。Saver和store有独立的连接池
# POSTGRES_MIN_CONNECTIONS_PER_POOL=1
# POSTGRES_MAX_CONNECTIONS_PER_POOL= 3

# OpenWeatherMap API密钥
OPENWEATHERMAP_API_KEY=

# 添加用于运行ollama
# OLLAMA_MODEL=llama3.2
# 注意：如果在docker中运行服务且在裸机上运行ollama，请设置OLLAMA_BASE_URL
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# 添加用于运行Azure OpenAI
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_DEPLOYMENT_MAP={"gpt-4o": "gpt-4o-deployment", "gpt-4o-mini": "gpt-4o-mini-deployment"}

# 代理URL：用于Streamlit应用 - 如果未设置，默认为http://{HOST}:{PORT}
# AGENT_URL=http://localhost:8080

# LANGFUSE配置
#LANGFUSE_TRACING=true
#LANGFUSE_PUBLIC_KEY=pk-...
#LANGFUSE_SECRET_KEY=sk-lf-....
#LANGFUSE_HOST=http://localhost:3000

# GitHub MCP代理配置
# GitHub个人访问令牌（GitHub MCP服务器必需）
# 如果未设置，GitHub MCP代理将没有工具
GITHUB_PAT=

# 安全防护配置
# 是否启用安全防护（提示注入检测），默认为true
ENABLE_SAFEGUARD=true

# 语音功能（可选）
# 注意：语音功能在客户端（Streamlit应用）侧配置，不在服务器（API）侧。
# 需要设置OPENAI_API_KEY（见上文）。
# 设置提供商名称以启用语音输入/输出。留空以禁用。
VOICE_STT_PROVIDER=        # 语音转文本提供商（目前仅支持'openai'）
VOICE_TTS_PROVIDER=        # 文本转语音提供商（目前仅支持'openai'）

# ==========================================
# Redis Configuration (Required for caching, rate limiting, Celery)
# ==========================================
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=50

# ==========================================
# JWT Authentication Configuration
# ==========================================
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# Rate Limiting Configuration
# ==========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_ANONYMOUS=10/minute
RATE_LIMIT_AUTHENTICATED=60/minute
RATE_LIMIT_LOGIN=5/minute

# ==========================================
# SQLAlchemy Connection Pool Configuration
# ==========================================
SQLALCHEMY_POOL_SIZE=5
SQLALCHEMY_MAX_OVERFLOW=10

# ==========================================
# PostgreSQL Pool Optimization
# ==========================================
POSTGRES_POOL_OPEN_TIMEOUT=30
POSTGRES_POOL_CLOSE_TIMEOUT=10
POSTGRES_POOL_MAX_IDLE_TIME=300

# ==========================================
# Celery Configuration
# ==========================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_CONCURRENCY=4
